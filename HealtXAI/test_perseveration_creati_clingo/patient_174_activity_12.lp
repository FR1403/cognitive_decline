expected_count(sort_and_fold_a_basketful_of_clothing_containing_mens_womens_and_childrens_articles, participant_sortsfolds_the_laundry, 1).

action_gap(sort_and_fold_a_basketful_of_clothing_containing_mens_womens_and_childrens_articles, participant_moves_to_the_hallway_closet, 240000).
action_gap(sort_and_fold_a_basketful_of_clothing_containing_mens_womens_and_childrens_articles, participant_locates_the_laundry_basket, 18000).
action_gap(sort_and_fold_a_basketful_of_clothing_containing_mens_womens_and_childrens_articles, participant_moves_to_the_couch, 240000).
action_gap(sort_and_fold_a_basketful_of_clothing_containing_mens_womens_and_childrens_articles, participant_sortsfolds_the_laundry, 240000).


% ===============================
% Level B - Execution observation
% ===============================

instance(i_p174_a13, sort_and_fold_a_basketful_of_clothing_containing_mens_womens_and_childrens_articles).

% raw_performed(Instance, Action, Order, TimeMs)

raw_performed(i_p174_a13, participant_moves_to_the_hallway_closet, 1, 39411000).
raw_performed(i_p174_a13, participant_locates_the_laundry_basket, 2, 39420704).
raw_performed(i_p174_a13, participant_locates_the_laundry_basket, 3, 39420718).
raw_performed(i_p174_a13, participant_moves_to_the_couch, 4, 39421957).
raw_performed(i_p174_a13, participant_sortsfolds_the_laundry, 5, 39422362).
raw_performed(i_p174_a13, participant_sortsfolds_the_laundry, 6, 39424719).
raw_performed(i_p174_a13, participant_sortsfolds_the_laundry, 7, 39491417).
raw_performed(i_p174_a13, participant_sortsfolds_the_laundry, 8, 39530239).
raw_performed(i_p174_a13, participant_sortsfolds_the_laundry, 9, 39537082).
raw_performed(i_p174_a13, participant_sortsfolds_the_laundry, 10, 39548092).
raw_performed(i_p174_a13, participant_sortsfolds_the_laundry, 11, 39620606).
raw_performed(i_p174_a13, participant_sortsfolds_the_laundry, 12, 39627532).
raw_performed(i_p174_a13, participant_sortsfolds_the_laundry, 13, 39678258).
raw_performed(i_p174_a13, participant_sortsfolds_the_laundry, 14, 39679531).

prev_same(I,X,T1,T2) :-
    raw_performed(I,X,_,T1),
    raw_performed(I,X,_,T2),
    T1 < T2,
    not between_same_time(I,X,T1,T2).

between_same_time(I,X,T1,T2) :-
    raw_performed(I,X,_,T1),
    raw_performed(I,X,_,T2),
    raw_performed(I,X,_,Tm),
    T1 < Tm,
    Tm < T2.

episode_start(I,X,T) :-
    raw_performed(I,X,_,T),
    not prev_same(I,X,_,T).

episode_start(I,X,T2) :-
    prev_same(I,X,T1,T2),
    instance(I,A),
    action_gap(A,X,G),
    T2 - T1 > G.

performed(I,X,Tstart) :-
    episode_start(I,X,Tstart).


% ===========================
% Level C - Anomaly detection
% ===========================


performed_count(I,X,M) :-
    instance(I,_),
    action(X),
    M = #count { T : performed(I,X,T) }.

perseveration(I,X) :-
    instance(I,A),
    expected_count(A,X,N),
    performed_count(I,X,M),
    M > N.

#show perseveration/2.

